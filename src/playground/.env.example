# Azure AI Foundry Configuration
# Copy this file to .env.local and fill in your values
#
# IMPORTANT: Do NOT use the VITE_ prefix for secrets.
# Variables without the VITE_ prefix are only available to the server-side
# Vite plugin (Node.js process) and are never embedded in the browser bundle.

# Your Azure AI Foundry project endpoint
# Find this in: Azure AI Foundry portal > Project > Overview > Endpoint
AZURE_FOUNDRY_ENDPOINT=https://your-project.services.ai.azure.com

# Your Azure AI Foundry API key
# Find this in: Azure AI Foundry portal > Project > Settings > API keys
AZURE_FOUNDRY_API_KEY=your-api-key-here

# Name of your deployed chat model (e.g., gpt-4o, gpt-35-turbo)
# Find this in: Azure AI Foundry portal > Deployments
AZURE_FOUNDRY_DEPLOYMENT=gpt-4o

# Name of your deployed DALL-E model (e.g., dall-e-3)
# Find this in: Azure AI Foundry portal > Deployments
AZURE_DALLE_DEPLOYMENT=dall-e-3

# Standard OpenAI API key (used when Azure endpoint/key are not set)
OPENAI_API_KEY=your-openai-api-key-here

# ChatKit workflow ID (required for the Chat page)
CHATKIT_WORKFLOW_ID=your-workflow-id-here
